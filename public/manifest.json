{
    "manifest_version": 3,
    "name": "Web Debloater",
    "version": "2026.3.25.2136",
    "description": "Auto-updating zone-based website debloater and enhancer",
    "permissions": [
        "storage",
        "alarms",
        "scripting",
        "notifications"
    ],
    "host_permissions": [
        "*://*.youtube.com/*",
        "*://*.github.com/*",
        "*://*.instagram.com/*",
        "https://raw.githubusercontent.com/*"
    ],
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "options_page": "index.html",
    "action": {
        "default_title": "Web Debloater Settings"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "page-scripts/trusted-types-bypass.js"
            ],
            "run_at": "document_start",
            "all_frames": false
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "scripts/youtube/**/*.js",
                "scripts/github/**/*.js",
                "scripts/instagram/**/*.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    }
}
