# Environment Variables Configuration
# Copy this file to .env and update with your values

# Selector Update URL
# URL pointing to your remote selectors.json file
# Can be GitHub raw URL, your own server, CDN, etc.
VITE_SELECTORS_URL=https://raw.githubusercontent.com/IonutDaniel99/debloater-selectors/refs/heads/main/selectors.json

# Update Check Interval (in hours)
# How often to automatically check for selector updates
# Default: 24 hours
VITE_UPDATE_INTERVAL_HOURS=24

# Alarm Name
# Name used for Chrome alarm that triggers update checks
# Default: selector-update-check
VITE_ALARM_NAME=selector-update-check
