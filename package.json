{
  "name": "web-debloater-extension",
  "version": "1.0.2",
  "description": "Zone-based auto-updating Chrome extension for debloating websites",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prebuild": "node scripts/update-version.js",
    "build:beta": "npm run prebuild && npm run build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "version:update": "node scripts/update-version.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.258",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
